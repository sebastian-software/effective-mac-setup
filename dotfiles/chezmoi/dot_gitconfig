[user]
  # GitHub noreply keeps a personal email address out of public commit metadata
  # while still associating commits with the GitHub account.
  name = Sebastian Werner
  email = swernerx@users.noreply.github.com

[init]
  defaultBranch = main

[pull]
  rebase = false

[push]
  autoSetupRemote = true

[fetch]
  prune = true

[rerere]
  enabled = true

[core]
  excludesfile = ~/.gitignore_global

[branch]
  sort = -committerdate

[tag]
  sort = version:refname
[credential "https://github.com"]
  helper =
  helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
  helper =
  helper = !/opt/homebrew/bin/gh auth git-credential
