# Keep PATH entries unique when this file is sourced repeatedly during dotfile
# work. This mirrors the small-shell-helper style seen in holman/dotfiles.
typeset -U path PATH

# Node.js versions are managed by fnm instead of Homebrew Node.
eval "$(fnm env --use-on-cd --shell zsh)"

# Zed is the primary editor here. "--wait" keeps Git and other CLI tools from
# continuing before the editor window is closed.
export EDITOR="zed --wait"
export VISUAL="zed --wait"

# Prefer a German UTF-8 locale for CLI tools while keeping the setting explicit
# and reproducible across fresh Macs.
export LANG="de_DE.UTF-8"
export LC_ALL="de_DE.UTF-8"

# Give memory-hungry Node.js tools more headroom globally for large frontend
# builds, type checks, and code-generation tasks.
export NODE_OPTIONS="${NODE_OPTIONS:+$NODE_OPTIONS }--max-old-space-size=16384"

# Go tools installed with "go install" land in GOBIN. Keep this explicit so
# project CLIs are available on fresh machines.
export GOPATH="${GOPATH:-$HOME/go}"
export GOBIN="${GOBIN:-$GOPATH/bin}"
path=("$GOBIN" $path)

# Rustup installs Cargo tools here. Keep this conditional so a fresh shell
# still works before the Rust toolchain has been initialized.
[[ -d "$HOME/.cargo/bin" ]] && path=("$HOME/.cargo/bin" $path)

# Navigation helpers. Inspired by the compact directory aliases commonly seen
# in mathiasbynens/dotfiles and holman/dotfiles.
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias -- -='cd -'

mkcd() {
  mkdir -p "$1" && cd "$1"
}

reload() {
  exec zsh
}

# Better listing/search defaults without overriding POSIX muscle memory.
# Inspired by recurring eza/bat/rg patterns in modern dotfiles collections.
alias ll='eza -la --git'
alias la='eza -a'
alias search='rg'

# Filesystem helpers. Keep destructive operations explicit: rm/cp/mv are not
# aliased. cleanup-dsstore is a macOS staple as seen in mathiasbynens/dotfiles.
alias mkdir='mkdir -p'
alias dfh='df -h'
alias duh='du -h'

ducks() {
  du -cksh -- ./*(N) ./.*(N) 2>/dev/null | sort -hr | head -n 20
}

cleanup-dsstore() {
  find "${1:-.}" -name .DS_Store -type f -delete
}

# Git shortcuts. Short shell aliases are intentionally kept close to common
# oh-my-zsh/holman-style conventions while the richer aliases live in Git.
alias g='git'
alias gs='git status --short --branch'
alias ga='git add'
alias gc='git commit'
alias gcm='git commit -m'
alias gp='git push'
alias gpl='git pull'
alias gl='git lg'
alias gco='git checkout'
alias gb='git branch --sort=-committerdate'
alias gundo='git reset --soft HEAD~1'

# GitHub CLI helpers. These prefer gh over hand-parsing remotes, which keeps the
# aliases simple and robust across HTTPS/SSH remotes.
repo() {
  gh repo view --web "$@"
}

pr() {
  gh pr view --web "$@"
}

ci() {
  gh pr checks "$@"
}

issues() {
  gh issue list --web "$@"
}

clonecd() {
  if [[ $# -ne 1 ]]; then
    echo "usage: clonecd <owner/repo>" >&2
    return 2
  fi

  local repo="$1"
  local dir="${repo##*/}"
  dir="${dir%.git}"
  gh repo clone "$repo" && cd "$dir"
}

repos-update() {
  local root="${1:-.}"
  local current_dir="$PWD"
  local repo

  find "$root" -maxdepth 4 -type d -name .git -prune -print | sort | while IFS= read -r repo; do
    local worktree="${repo:h}"
    printf -- '- Updating: %s\n' "${worktree#$root/}"

    if ! git -C "$worktree" diff --quiet || ! git -C "$worktree" diff --cached --quiet; then
      printf '  skipped: working tree has local changes\n' >&2
      continue
    fi

    git -C "$worktree" pull --ff-only
  done

  cd "$current_dir"
}

# Backward-compatible muscle-memory alias from the previous setup.
repupd() {
  repos-update "$@"
}

# Dotfile and package-management checks. Mutating commands like "chezmoi apply"
# and "brew bundle dump" stay intentionally explicit.
alias czs='chezmoi status'
alias czd='chezmoi diff'
alias brewc='brew bundle check --no-upgrade --file Brewfile'

setup-doctor() {
  local setup_repo="${EFFECTIVE_MAC_SETUP:-$HOME/Workspace/effective-mac-setup}"
  if [[ ! -x "$setup_repo/scripts/doctor.sh" ]]; then
    echo "setup doctor not found at $setup_repo/scripts/doctor.sh" >&2
    return 127
  fi

  "$setup_repo/scripts/doctor.sh" "$@"
}

# Trash workflow. Inspired by dotfiles that avoid making rm safer by surprise:
# keep rm untouched and expose an explicit "move to Trash" command instead.
del() {
  local trash_cmd
  if [[ -x /opt/homebrew/opt/trash/bin/trash ]]; then
    trash_cmd="/opt/homebrew/opt/trash/bin/trash"
  elif command -v trash >/dev/null 2>&1; then
    trash_cmd="trash"
  else
    echo "trash CLI is not installed. Run: brew bundle --file Brewfile" >&2
    return 127
  fi

  "$trash_cmd" "$@"
}

# Small network diagnostics, as commonly seen in paulirish/dotfiles-style
# helper sets. Commands are explicit because some reach outside the machine.
myip() {
  curl -fsSL https://ifconfig.me
  echo
}

ports() {
  lsof -nP -iTCP -sTCP:LISTEN "$@"
}

flushdns() {
  sudo dscacheutil -flushcache
  sudo killall -HUP mDNSResponder
}

# Language workflow aliases for the current Go/Rust/Node setup.
alias gob='go build ./...'
alias got='go test ./...'
alias gor='go run .'
alias cc='cargo check'
alias ct='cargo test'
alias cr='cargo run'
alias run='npm run -s'
alias ni='npm install'
alias nci='npm ci'
alias nr='npm run'
alias nt='npm test'
alias rgr='rg -L'

# 1Password / SSH diagnostics and optional secret-backed environment variables.
# The actual SSH agent integration remains managed by 1Password.
#
# To expose selected secrets as global environment variables, create a local
# file at ~/.config/effective-mac-setup/op-env with lines like:
#
#   LINEAR_API_KEY=op://Private/Linear/API Key
#
# The file is intentionally not managed by this repo. Loading secrets into the
# global shell environment is convenient for direct CLI tools, but child
# processes can read their parent's environment, so only load what you need.
op-accounts() {
  command -v op >/dev/null 2>&1 || {
    echo "1Password CLI is not installed." >&2
    return 127
  }

  op account list
}

op-whoami() {
  command -v op >/dev/null 2>&1 || {
    echo "1Password CLI is not installed." >&2
    return 127
  }

  op whoami
}

op-env-load() {
  local quiet=false
  if [[ "${1:-}" == "--quiet" ]]; then
    quiet=true
    shift
  fi

  local env_file="${1:-${OP_ENV_FILE:-$HOME/.config/effective-mac-setup/op-env}}"
  [[ -r "$env_file" ]] || return 0

  command -v op >/dev/null 2>&1 || {
    $quiet || echo "1Password CLI is not installed." >&2
    return 127
  }

  local loaded=0
  local failed=0
  local line name ref value

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    [[ "$line" == *"="* ]] || continue

    name="${line%%=*}"
    ref="${line#*=}"
    name="${name//[[:space:]]/}"

    if [[ ! "$name" =~ '^[A-Za-z_][A-Za-z0-9_]*$' ]]; then
      $quiet || echo "Skipping invalid environment variable name: $name" >&2
      failed=$((failed + 1))
      continue
    fi

    if value="$(op read "$ref" 2>/dev/null)"; then
      export "$name=$value"
      loaded=$((loaded + 1))
    else
      $quiet || echo "Could not read 1Password secret for $name" >&2
      failed=$((failed + 1))
    fi
  done < "$env_file"

  $quiet || echo "Loaded $loaded 1Password-backed environment variables from $env_file."
  [[ "$failed" -eq 0 ]]
}

op-env-edit() {
  local env_file="${OP_ENV_FILE:-$HOME/.config/effective-mac-setup/op-env}"
  mkdir -p "${env_file:h}"
  if [[ -n "${EDITOR:-}" ]]; then
    ${(z)EDITOR} "$env_file"
  else
    zed --wait "$env_file"
  fi
}

# Auto-load only when the local mapping file exists. Set OP_ENV_AUTO_LOAD=0 to
# disable this for a shell session.
if [[ "${OP_ENV_AUTO_LOAD:-1}" != "0" ]]; then
  op-env-load --quiet
fi

ssh-agent-info() {
  echo "SSH_AUTH_SOCK=${SSH_AUTH_SOCK:-}"
  ssh-add -l
}

gh-ssh-test() {
  ssh -T git@github.com
}

eval "$(starship init zsh)"
