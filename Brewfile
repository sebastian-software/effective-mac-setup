# Git: current Git CLI instead of Apple's older system Git; core for all repo work.
# https://git-scm.com
brew "git"

# GitHub CLI: auth, repo, issue, PR, and Actions workflows from the terminal.
# https://cli.github.com/
brew "gh"

# fnm: fast Node.js version manager; keeps Node out of Homebrew so projects can pin versions.
# https://github.com/Schniz/fnm
brew "fnm"

# Starship: small cross-shell prompt with useful Git/runtime context.
# https://starship.rs/
brew "starship"

# ripgrep: very fast recursive search; preferred over grep for codebases.
# https://github.com/BurntSushi/ripgrep
brew "ripgrep"

# fd: fast, friendly find replacement for locating files in projects.
# https://github.com/sharkdp/fd
brew "fd"

# jq: command-line JSON processor for API responses, configs, and logs.
# https://jqlang.github.io/jq/
brew "jq"

# bat: cat replacement with syntax highlighting and Git-aware output.
# https://github.com/sharkdp/bat
brew "bat"

# eza: maintained ls replacement with clearer file listings.
# https://eza.rocks/
brew "eza"

# mas: Mac App Store CLI so App Store apps can be represented in this Brewfile.
# https://github.com/mas-cli/mas
brew "mas"

# chezmoi: dotfile manager; used here in symlink mode with source in dotfiles/chezmoi.
# https://chezmoi.io/
brew "chezmoi"

# dockutil: manages Dock app links without hand-writing Dock bookmark plists.
# https://github.com/kcrawford/dockutil
brew "dockutil"

# Go: infrastructure and CLI language, useful for OSS work such as Ferrocat.
# https://go.dev/
brew "go"

# rustup-init: Rust toolchain installer; rustc/cargo are managed by rustup, not Homebrew rust.
# https://rust-lang.github.io/rustup/
brew "rustup-init"

# GitHub Desktop: visual Git/GitHub client for repo review and occasional GUI workflows.
# https://desktop.github.com/
cask "github"

# Zed: primary editor on this setup.
# https://zed.dev/
cask "zed"

# Firefox: independent browser engine for daily browsing and web compatibility checks.
# https://www.mozilla.org/firefox/
cask "firefox"

# Google Chrome: Chromium fallback for site testing and cases where Helium is not enough.
# https://www.google.com/chrome/
cask "google-chrome"

# Pages: Apple word processor; installed from the Mac App Store.
# https://apps.apple.com/app/id361309726
