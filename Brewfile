# https://apps.apple.com/app/id462058435
mas "Microsoft Excel", id: 462058435

# Microsoft PowerPoint: Office presentation editor; installed from the Mac App Store.
# https://apps.apple.com/app/id462062816
mas "Microsoft PowerPoint", id: 462062816

# Xcode: Apple developer tools and SDKs; installed from the Mac App Store.
# https://apps.apple.com/app/id497799835
mas "Xcode", id: 497799835

# Things: personal task manager; installed from the Mac App Store.
# https://apps.apple.com/app/id904280696
mas "Things", id: 904280696

# Fantastical: calendar app; installed from the Mac App Store.
# https://apps.apple.com/app/id975937182
